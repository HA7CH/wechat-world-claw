{
  "name": "wechat-world-push",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "login": "tsx scripts/login.mts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 execute wechat-world-push --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute wechat-world-push --remote --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "qrcode-terminal": "^0.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wechat-ilink-client": "^0.1.0",
    "wrangler": "^4"
  }
}
