{
  "name": "wechat-world-push",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "mkdir -p node_modules/@cf-wasm/resvg/dist/lib && cp node_modules/@resvg/resvg-wasm/index_bg.wasm node_modules/@cf-wasm/resvg/dist/lib/resvg.wasm",
    "login": "tsx scripts/login.mts",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 execute wechat-world-push --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute wechat-world-push --remote --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@types/react": "^19.2.14",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.6",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wechat-ilink-client": "^0.1.0",
    "wrangler": "^4"
  },
  "dependencies": {
    "@cf-wasm/resvg": "^0.3.4",
    "@cf-wasm/satori": "^0.3.6",
    "@noble/hashes": "^2.2.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "@types/qrcode-generator": "^0.0.16",
    "qrcode-generator": "^2.0.4",
    "satori": "^0.26.0"
  }
}
